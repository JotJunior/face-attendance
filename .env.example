# Copie para `.env` e preencha. NUNCA commite o .env real.
# cp .env.example .env

# --- Infraestrutura local (Postgres / RabbitMQ no compose) ---
POSTGRES_PASSWORD=presenca_dev
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# --- Integração GOB (fonte/destino dos membros) — DADO REAL, obrigatório ---
GOB_STATE_URL=
GOB_STATE_TOKEN=

# --- Segredos do app (gerados aleatoriamente) ---
ADMIN_TOKEN=
WEBHOOK_PATH_SECRET=

# --- Política de retry / scheduler (opcional; defaults entre parênteses) ---
MEMBER_SYNC_INTERVAL_MINUTES=60
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_BACKOFF_MS=1000
WEBHOOK_RATE_LIMIT_PER_IP_PER_MIN=60
ADMIN_SYNC_MIN_INTERVAL_SECONDS=60

# --- Feature flags (opcional) ---
RUN_HTTP=true
RUN_SCHEDULER=true
RUN_WORKERS=true

# --- Dispositivos HikVision (ISAPI) — DADO REAL ---
# Repita incrementando o índice (1, 2, 3, ...) para cada dispositivo.
ISAPI_DEVICE_1_HOST=
ISAPI_DEVICE_1_USER=admin
ISAPI_DEVICE_1_PASSWORD=
